generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  admin

  @@map("user_role")
}

enum ItemStatus {
  available
  rented
  maintenance
  inactive

  @@map("item_status")
}

enum BookingStatus {
  pending_verification
  waiting_payment
  payment_pending
  paid
  approved
  rejected
  ongoing
  completed
  cancelled
  expired

  @@map("booking_status")
}

enum VerificationStatus {
  pending
  approved
  rejected

  @@map("verification_status")
}

enum ConditionType {
  before_rent
  after_rent

  @@map("condition_type")
}

enum PaymentProvider {
  midtrans

  @@map("payment_provider")
}

enum PaymentStatus {
  pending
  settlement
  capture
  deny
  cancel
  expire
  refund
  failure

  @@map("payment_status")
}

enum NotificationType {
  booking_created
  booking_approved
  booking_rejected
  payment_success
  payment_failed
  rental_reminder
  rental_completed
  system

  @@map("notification_type")
}

model Profile {
  id           BigInt   @id @default(autoincrement())
  auth_user_id String?  @unique @db.Uuid
  full_name    String   @db.VarChar(120)
  username     String?  @unique @db.Citext
  email        String   @unique @db.Citext
  phone        String?  @db.VarChar(30)
  role         UserRole @default(customer)
  avatar_path  String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)

  bookings Booking[] @relation("CustomerBookings")

  identity_verifications IdentityVerification[] @relation("IdentitySubmittedBy")
  reviewed_identities    IdentityVerification[] @relation("IdentityReviewedBy")

  condition_verifications ConditionVerification[] @relation("ConditionSubmittedBy")
  reviewed_conditions     ConditionVerification[] @relation("ConditionReviewedBy")

  notifications Notification[]
  device_tokens DeviceToken[]

  @@map("profiles")
}

model Category {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique @db.VarChar(80)
  slug        String   @unique @db.VarChar(100)
  icon_name   String?  @db.VarChar(80)
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  items Item[]

  @@map("categories")
}

model Item {
  id                BigInt     @id @default(autoincrement())
  category_id       BigInt
  name              String     @db.VarChar(150)
  slug              String     @unique @db.VarChar(180)
  brand             String?    @db.VarChar(100)
  model             String?    @db.VarChar(100)
  serial_number     String     @unique @db.VarChar(100)
  description       String?
  daily_price       Decimal    @db.Decimal(12, 2)
  replacement_value Decimal?   @db.Decimal(12, 2)
  status            ItemStatus @default(available)
  is_active         Boolean    @default(true)
  specifications    Json      @default("{}")
  created_by        BigInt?
  updated_by        BigInt?
  created_at        DateTime   @default(now()) @db.Timestamptz(6)
  updated_at        DateTime   @default(now()) @db.Timestamptz(6)

  category Category    @relation(fields: [category_id], references: [id])
  images   ItemImage[]

  booking_items           BookingItem[]
  condition_verifications ConditionVerification[]

  @@map("items")
}

model ItemImage {
  id             BigInt   @id @default(autoincrement())
  item_id        BigInt
  storage_bucket String   @default("item-images") @db.VarChar(100)
  storage_path   String
  public_url     String?
  is_primary     Boolean  @default(false)
  sort_order     Int      @default(0)
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  item Item @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@map("item_images")
}

model Booking {
  id                BigInt        @id @default(autoincrement())
  booking_code      String        @unique @db.VarChar(30)
  customer_id       BigInt
  rental_start_date DateTime      @db.Date
  rental_end_date   DateTime      @db.Date
  total_days        Int?
  subtotal_amount   Decimal       @default(0) @db.Decimal(12, 2)
  service_fee       Decimal       @default(0) @db.Decimal(12, 2)
  total_amount      Decimal       @default(0) @db.Decimal(12, 2)
  status            BookingStatus @default(pending_verification)
  customer_note     String?
  admin_note        String?
  approved_by       BigInt?
  approved_at       DateTime?     @db.Timestamptz(6)
  rejected_by       BigInt?
  rejected_at       DateTime?     @db.Timestamptz(6)
  cancelled_at      DateTime?     @db.Timestamptz(6)
  expired_at        DateTime?     @db.Timestamptz(6)
  created_at        DateTime      @default(now()) @db.Timestamptz(6)
  updated_at        DateTime      @default(now()) @db.Timestamptz(6)

  customer Profile @relation("CustomerBookings", fields: [customer_id], references: [id])

  booking_items           BookingItem[]
  identity_verification   IdentityVerification?
  condition_verifications ConditionVerification[]
  payment                 Payment?

  @@map("bookings")
}

model BookingItem {
  id                   BigInt   @id @default(autoincrement())
  booking_id           BigInt
  item_id              BigInt
  item_name_snapshot   String   @db.VarChar(150)
  daily_price_snapshot Decimal  @db.Decimal(12, 2)
  rental_start_date    DateTime @db.Date
  rental_end_date      DateTime @db.Date
  line_total           Decimal? @db.Decimal(12, 2)
  created_at           DateTime @default(now()) @db.Timestamptz(6)

  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  item    Item    @relation(fields: [item_id], references: [id])

  @@unique([booking_id, item_id])
  @@map("booking_items")
}

model IdentityVerification {
  id                BigInt             @id @default(autoincrement())
  booking_id        BigInt             @unique
  user_id           BigInt
  document_type     String             @default("ktp") @db.VarChar(30)
  ktp_name          String?            @db.VarChar(120)
  ktp_number_masked String?            @db.VarChar(40)
  photo_bucket      String             @default("identity-documents") @db.VarChar(100)
  photo_path        String
  latitude          Decimal            @db.Decimal(10, 7)
  longitude         Decimal            @db.Decimal(10, 7)
  address_text      String?
  taken_at          DateTime           @db.Timestamptz(6)
  status            VerificationStatus @default(pending)
  reviewed_by       BigInt?
  reviewed_at       DateTime?          @db.Timestamptz(6)
  rejection_reason  String?
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime           @default(now()) @db.Timestamptz(6)

  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  user     Profile  @relation("IdentitySubmittedBy", fields: [user_id], references: [id], onDelete: Cascade)
  reviewer Profile? @relation("IdentityReviewedBy", fields: [reviewed_by], references: [id])

  @@map("identity_verifications")
}

model ConditionVerification {
  id           BigInt             @id @default(autoincrement())
  booking_id   BigInt
  item_id      BigInt
  submitted_by BigInt
  type         ConditionType
  photo_bucket String             @default("condition-photos") @db.VarChar(100)
  photo_path   String
  latitude     Decimal            @db.Decimal(10, 7)
  longitude    Decimal            @db.Decimal(10, 7)
  address_text String?
  note         String?
  taken_at     DateTime           @db.Timestamptz(6)
  status       VerificationStatus @default(pending)
  reviewed_by  BigInt?
  reviewed_at  DateTime?          @db.Timestamptz(6)
  created_at   DateTime           @default(now()) @db.Timestamptz(6)
  updated_at   DateTime           @default(now()) @db.Timestamptz(6)

  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  item    Item    @relation(fields: [item_id], references: [id], onDelete: Cascade)

  submitter Profile  @relation("ConditionSubmittedBy", fields: [submitted_by], references: [id], onDelete: Cascade)
  reviewer  Profile? @relation("ConditionReviewedBy", fields: [reviewed_by], references: [id])

  @@unique([booking_id, item_id, type])
  @@map("condition_verifications")
}

model Payment {
  id                BigInt          @id @default(autoincrement())
  booking_id        BigInt          @unique
  provider          PaymentProvider @default(midtrans)
  external_order_id String          @unique @db.VarChar(100)
  transaction_id    String?         @db.VarChar(150)
  snap_token        String?
  redirect_url      String?
  gross_amount      Decimal         @db.Decimal(12, 2)
  payment_type      String?         @db.VarChar(80)
  status            PaymentStatus   @default(pending)
  fraud_status      String?         @db.VarChar(80)
  paid_at           DateTime?       @db.Timestamptz(6)
  expired_at        DateTime?       @db.Timestamptz(6)
  raw_response      Json            @default("{}")
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime        @default(now()) @db.Timestamptz(6)

  booking Booking        @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  events  PaymentEvent[]

  @@map("payments")
}

model PaymentEvent {
  id          BigInt         @id @default(autoincrement())
  payment_id  BigInt
  event_type  String         @db.VarChar(100)
  status      PaymentStatus?
  payload     Json           @default("{}")
  received_at DateTime       @default(now()) @db.Timestamptz(6)

  payment Payment @relation(fields: [payment_id], references: [id], onDelete: Cascade)

  @@map("payment_events")
}

model Notification {
  id         BigInt           @id @default(autoincrement())
  user_id    BigInt
  type       NotificationType @default(system)
  title      String           @db.VarChar(150)
  body       String
  data       Json             @default("{}")
  is_read    Boolean          @default(false)
  read_at    DateTime?        @db.Timestamptz(6)
  created_at DateTime         @default(now()) @db.Timestamptz(6)

  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model DeviceToken {
  id           BigInt   @id @default(autoincrement())
  user_id      BigInt
  fcm_token    String   @unique
  platform     String   @db.VarChar(30)
  device_name  String?  @db.VarChar(120)
  is_active    Boolean  @default(true)
  last_seen_at DateTime @default(now()) @db.Timestamptz(6)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)

  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}